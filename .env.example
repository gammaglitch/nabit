POSTGRES_USER=nabit
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nabit

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Set both flags to false for a single-user deployment behind a trusted boundary.
# AUTH_REQUIRED=false
# NEXT_PUBLIC_AUTH_REQUIRED=false

# Override only when the browser should reach the API on a different public URL.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/trpc

# Only needed when using `compose.hosted-db.yml`.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Optional API auth settings.
# ALLOWED_EMAILS=alice@example.com,bob@example.com
# API_TOKEN=
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
