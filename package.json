{
  "name": "nabit",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check": "turbo check",
    "dev": "turbo dev",
    "fix": "turbo fix",
    "lint": "turbo lint",
    "style:check": "turbo style:check",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "verify": "turbo verify",
    "scaffold:feature": "bun scripts/scaffold-feature.ts",
    "format": "biome format --write .",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "turbo": "2.8.20",
    "typescript": "6.0.2"
  }
}
