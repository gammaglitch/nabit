{
  "name": "@repo/api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check": "bun run lint && bun run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "dev": "bun --watch src/index.ts",
    "fix": "biome check --write .",
    "lint": "biome lint .",
    "start": "bun src/index.ts",
    "style:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "test": "bun test",
    "typecheck": "tsc --project tsconfig.json",
    "verify": "bun run check && bun run style:check && bun run build"
  },
  "dependencies": {
    "@fastify/cors": "11.0.1",
    "@fastify/websocket": "11.2.0",
    "@mozilla/readability": "^0.6.0",
    "@repo/ingestors": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/trpc": "workspace:*",
    "@trpc/server": "11.15.1",
    "drizzle-orm": "0.45.1",
    "fastify": "5.8.4",
    "fastify-plugin": "5.1.0",
    "jose": "6.2.2",
    "jsdom": "^29.0.1",
    "postgres": "3.4.7",
    "tiny-typed-emitter": "2.1.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/turndown": "^5.0.6",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.10"
  }
}
