HOST=0.0.0.0
PORT=3001
WEBSOCKETS_ENABLED=false
DATABASE_URL=
# Set to "false" for single-user / private-network deployments. Every request
# gets a synthetic admin user and ALLOWED_EMAILS is ignored. Defaults to "true".
# AUTH_REQUIRED=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
# Comma-separated list of emails allowed to access the app (leave empty to allow all):
# ALLOWED_EMAILS=alice@example.com,bob@example.com
# Static API token for scripts/automation (e.g. Tampermonkey):
# API_TOKEN=
# Optional overrides:
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
