{
  "name": "@repo/web",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3002",
    "build": "next build",
    "check": "bun run lint && bun run typecheck",
    "start": "next start",
    "fix": "biome check --write .",
    "lint": "biome lint .",
    "style:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "verify": "bun run check && bun run style:check && bun run build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@repo/auth": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/trpc": "workspace:*",
    "@supabase/supabase-js": "2.100.1",
    "@tanstack/react-query": "5.95.2",
    "@trpc/client": "11.15.1",
    "@trpc/react-query": "11.15.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "0.0.1",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0"
