    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "jsdom": "29.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
